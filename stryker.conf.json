{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "command",
  "commandRunner": {
    "command": "npx tsx test/run.ts"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "src/core/**/*.ts",
    "!src/core/request-builder.ts"
  ],
  "reporters": ["clear-text", "html", "progress"],
  "htmlReporter": { "fileName": "reports/mutation/index.html" },
  "clearTextReporter": { "allowColor": true, "maxTestsToLog": 0 },
  "timeoutMS": 60000,
  "concurrency": 4,
  "thresholds": { "high": 95, "low": 90, "break": 90 },
  "dashboard": {
    "project": "github.com/zuub-don/tutela",
    "version": "main",
    "module": "core"
  }
}

